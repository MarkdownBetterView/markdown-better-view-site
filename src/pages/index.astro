---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import Hero from '../components/Hero.astro';
import FeatureSection from '../components/FeatureSection.astro';
import FeatureGrid from '../components/FeatureGrid.astro';
---

<BaseLayout
  title="Markdown Better View — a fast, native macOS Markdown viewer"
  description="A fast, native macOS Markdown viewer. Themes, live reload, table of contents, instant find, Quick Look, math, and Mermaid — sandboxed, with no tracking."
>
  <Nav slot="nav" />
  <Hero />

  <section id="features">
    <FeatureSection
      label="// quick look"
      title="Preview without opening the app."
      body="Press Space in Finder and read your Markdown rendered, right there — plus rich thumbnails in every folder."
      side="normal"
      video="quick-look"
    />
    <FeatureSection
      label="// live reload"
      title="Save, and it’s already updated."
      body="Edit in any editor — the view reloads instantly. No refresh, no flicker."
      side="alt"
      video="live-reload"
    />
    <FeatureSection
      label="// themes"
      title="Five themes. Real dark mode."
      body="Dracula, Solarized & more — switch live; follows the system appearance."
      side="normal"
      video="themes"
    />
    <FeatureSection
      label="// navigate"
      title="Built for long documents."
      body="Table of contents with scrollspy, instant find with match count, distraction-free reading mode."
      side="alt"
      video="navigate"
    />
    <FeatureSection
      label="// open"
      title="A whole folder, in tabs."
      body="Point it at a folder — every Markdown file opens as a native tab."
      side="normal"
      video="folder-tabs"
    />
    <FeatureGrid />
  </section>

  <Footer slot="footer" />

  <script
    type="application/ld+json"
    set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'SoftwareApplication',
      name: 'Markdown Better View',
      applicationCategory: 'UtilitiesApplication',
      operatingSystem: 'macOS 15.0 or later',
      description:
        'A fast, native macOS Markdown viewer with Quick Look, live reload, themes, table of contents, instant find, math and Mermaid — one-time, no subscription.',
      url: 'https://markdownbetterview.com',
      downloadUrl: 'https://apps.apple.com/app/id6773928994',
      image: 'https://markdownbetterview.com/og.png',
      screenshot: 'https://markdownbetterview.com/og.png',
      author: { '@type': 'Person', name: 'Martin Bednář' },
      offers: {
        '@type': 'Offer',
        price: '9.99',
        priceCurrency: 'USD',
        availability: 'https://schema.org/InStock',
        url: 'https://apps.apple.com/app/id6773928994',
      },
      featureList: [
        'Quick Look preview and rich thumbnails in Finder',
        'Live reload on save',
        'Follow Edits — the preview scrolls to whatever just changed',
        'Five themes with a real dark mode that follows the system',
        'Table of contents with scrollspy',
        'Instant find with a live match count',
        'Distraction-free reading mode',
        'Open a whole folder as native tabs',
        'KaTeX math and Mermaid diagrams',
        'Syntax highlighting for 30+ languages',
        'Sandboxed, no tracking, remote network blocked',
      ],
    })}
  />
</BaseLayout>
