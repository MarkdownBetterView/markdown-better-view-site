---
// "Everything else" grid — ported from hero-plus-features-v2.html
// (.gsec / .ggrid / .gcell). 8 cells.
const cells = [
  { ic: '∑', title: 'Math & Mermaid', sub: 'KaTeX + diagrams' },
  { ic: '⌘', title: 'Quick Look', sub: 'preview + thumbnail' },
  { ic: '⇩', title: 'Export PDF', sub: '& print' },
  { ic: '🔗', title: 'Deep links', sub: 'mdbv://' },
  { ic: '{ }', title: 'Code highlight', sub: 'GFM tables' },
  { ic: '🖼', title: 'Images', sub: 'lightbox' },
  { ic: '🔒', title: 'Private', sub: 'sandboxed · no tracking' },
  { ic: '􀣺', title: 'Native', sub: 'macOS 26' },
];
---

<section class="gsec">
  <h3>Everything else</h3>
  <div class="ggrid">
    {cells.map((c) => (
      <div class="gcell">
        <div class="ic">{c.ic}</div>
        <b>{c.title}</b>
        <span>{c.sub}</span>
      </div>
    ))}
  </div>
</section>
